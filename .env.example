# Segurança do protocolo EXP
EXP_SHARED_SECRET=troque-esta-chave-para-um-segredo-forte

# Endpoints do Juiz
ENXAME_JUIZ_URL=http://localhost:7700
JUIZ_WS_URL=ws://localhost:7700/exp
JUIZ_HOST_IP=127.0.0.1

# Metadados opcionais do nó
NODE_INDEX=1
NODE_ROLE=juiz
CLUSTER_ROLE=agente
NODE_ID=juiz-01
NODE_IP=127.0.0.1

# Busca local distribuída
NODE_DOCS_DIR=/data/docs
NODE_ZIM_DIR=/data/zim

# TLS (air-gapped)
TLS_CA_CERT=/etc/enxame/certs/ca.crt
TLS_CERT=/etc/enxame/certs/node.crt
TLS_KEY=/etc/enxame/certs/node.key

# Fuso horário sugerido
TZ=America/Cuiaba
